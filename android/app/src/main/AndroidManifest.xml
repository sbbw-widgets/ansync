<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- LAN discovery + QUIC transport. -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.CHANGE_WIFI_MULTICAST_STATE" />

    <!-- Persistent foreground for capture + input dispatch (Step 7d/e). -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CAMERA" />
    <!-- DATA_SYNC is the "no special operation" type. The service
         starts under this label whenever no capture / camera / mic is
         active so it can run as a plain QUIC client + input dispatch
         worker without claiming any of the restricted types. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Virtual camera relay (Step 10): host streams sensor frames
         from the Android camera into a v4l2loopback device. The
         runtime CAMERA prompt is requested when the user enables
         the camera feature; the setup notif covers the others. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />

    <!-- Audio bidirectional (Step 11): mic forwarding via AudioRecord,
         playback via AudioTrack. RECORD_AUDIO is required for the
         mic side; MODIFY_AUDIO_SETTINGS lets the router switch
         routing modes if needed. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />

    <!-- Required to draw the persistent companion notification widget
         in Step 11 (audio routing controls). -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Doze whitelist: lets the user grant the companion service a
         permanent exemption from idle-doze power restrictions. Without
         it Android can throttle Wi-Fi / CPU after ~30 min of screen-off
         and the host loses the QUIC session silently. The Setup notif
         walks the user through this — Google Play would reject a
         pre-installed apk that bundles the doze grant, so we ask. -->
    <uses-permission
        android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"
        tools:ignore="BatteryLife" />

    <!-- Auto-restart the companion service after device reboot (U4c). -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- "All files access". Received files land under
         /sdcard/Download/ansync/{host}/ so the user can browse them
         in any file manager / gallery without poking the notif. The
         app is sideloaded (no Play distribution) so the All-Files
         policy restriction does not apply. -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- Floating cursor overlay shown in real time while the host
         streams pointer events. The accessibility service queues the
         actual tap/drag gestures (which only land at the end of each
         segment); the overlay gives the user immediate visual
         feedback for where the next dispatch will fire. User must
         grant this from Settings → "Display over other apps" once;
         missing grant degrades to the no-cursor experience. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Android 14+ requires this for `setFullScreenIntent` to be
         honoured. With it (plus user grant under Settings → Special
         App Access → Full-screen intent) the pair notification
         auto-opens PairingActivity without a tap. Without the grant
         the notif still works as a tappable heads-up. -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <application
        android:label="@string/app_name"
        android:icon="@android:drawable/sym_def_app_icon"
        android:allowBackup="false"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.Material.Light.NoActionBar"
        tools:targetApi="34">

        <!--
            Headless companion. No launcher icon — every Activity below
            is either a transparent shim that pops a system dialog and
            finishes, or a full-screen overlay launched from a QSTile.
            The service is started by PairingReceiver / BootReceiver
            without any user-visible app surface.
        -->

        <!--
            Pure background companion: no launcher icon. Entry points
            are the SetupNotif heads-up + PairingReceiver broadcast +
            BootReceiver auto-restart. SetupStepActivity is the
            translucent shim the user lands in after tapping the
            setup notif — it MUST stay registered (PendingIntent
            target) but no MAIN/LAUNCHER intent-filter.

            NB: on aggressive OEMs (MIUI / EMUI / ColorOS) the lack
            of a launcher icon can keep the app in a frozen state
            until the user manually whitelists it under Battery /
            Autostart. We surface that hint in `SetupStep.MiuiAutostart`.
        -->
        <activity
            android:name=".SetupStepActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true" />

        <activity
            android:name=".GrantScreenCaptureActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true" />

        <!--
            Cable-pair driver. Launched by PairingReceiver after the
            host's am broadcast lands; runs the native bootstrap on a
            background thread so the receiver can return inside the
            ANR window, then starts AnsyncCompanionService directly.
            Pending grants are surfaced via the SetupNotif heads-up
            once the service is alive.
        -->
        <activity
            android:name=".PairingActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true"
            android:noHistory="true" />

        <activity
            android:name=".TouchpadActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <activity
            android:name=".GamepadActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden|navigation" />

        <!--
            Share entry point: registers under the system Share sheet
            (`ACTION_SEND` / `ACTION_SEND_MULTIPLE` for both
            `text/plain` and arbitrary streams). The QSTile launches
            it with no extras so it can pop ACTION_GET_CONTENT.
            Translucent so the share-sheet flow feels native to the
            sender app.
        -->
        <activity
            android:name=".ShareActivity"
            android:label="@string/share_label"
            android:exported="true"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="text/plain" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>

        <!-- Foreground service hosting the QUIC client, MediaProjection
             capture surface, and the audio route. Brought up by the
             user after granting MediaProjection. Step 7d wires the
             actual encode + transport. -->
        <service
            android:name=".AnsyncCompanionService"
            android:exported="false"
            android:foregroundServiceType="dataSync|mediaProjection|camera|microphone" />

        <!-- Cable-pairing entry point. Invoked by the host via
             `adb shell am broadcast`. Exported so the ADB shell can
             address it explicitly; intent action is namespaced. -->
        <receiver
            android:name=".PairingReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="org.gameros.ansync.action.PAIR" />
            </intent-filter>
        </receiver>

        <!-- Auto-restart after device boot or package upgrade (U4c). -->
        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Reverse-input handler: receives gesture dispatches from
             the host. Requires the user to enable it under Settings →
             Accessibility. Step 7e wires gesture dispatch + key
             injection. -->
        <service
            android:name=".AnsyncAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Notification mirror: forwards every status-bar notification
             the user has granted access to over the QUIC link. The
             user enables it under Settings → Apps → Special access →
             Notification access. -->
        <service
            android:name=".NotificationForwarder"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Quick Settings tiles (U4b). Users add them from Edit in
             the QS shade; tap dispatches to AnsyncCompanionService via
             a simple Intent so we don't need to bind. -->
        <service
            android:name=".tile.MirrorTile"
            android:label="@string/tile_mirror_label"
            android:icon="@android:drawable/stat_sys_data_bluetooth"
            android:exported="true"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".tile.TouchpadTile"
            android:label="@string/tile_touchpad_label"
            android:icon="@android:drawable/ic_menu_compass"
            android:exported="true"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".tile.MicShareTile"
            android:label="@string/tile_mic_label"
            android:icon="@android:drawable/ic_btn_speak_now"
            android:exported="true"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".tile.AudioSinkTile"
            android:label="@string/tile_audio_label"
            android:icon="@android:drawable/ic_lock_silent_mode_off"
            android:exported="true"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".tile.GamepadTile"
            android:label="@string/tile_gamepad_label"
            android:icon="@android:drawable/ic_menu_send"
            android:exported="true"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

        <service
            android:name=".tile.ShareTile"
            android:label="@string/tile_share_label"
            android:icon="@android:drawable/ic_menu_share"
            android:exported="true"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>
    </application>
</manifest>
